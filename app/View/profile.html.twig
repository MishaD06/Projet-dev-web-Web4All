{% extends 'layouts/base.html.twig' %}
{% set current_route = 'profile' %}
{% block title %}Mon profil{% endblock %}

{% block content %}
<div style="max-width:600px;margin:0 auto;">
    <div class="card">
        <div class="card-header">
            <h2><i class="fas fa-user-circle" style="color:var(--violet);margin-right:.5rem;"></i> Mon profil</h2>
        </div>

        {# Ce partial gère déjà l'affichage des erreurs (le bloc rose en haut sur ta photo) #}
        {% include '_partials/alerts.html.twig' %}

        <form method="POST" action="/profil" novalidate style="margin-top: 1rem;">
            {{ csrf_field()|raw }}
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                <div class="form-group">
                    <label for="nom">Nom <span style="color:var(--red)">*</span></label>
                    <input type="text" class="form-control" id="nom" name="nom"
                           value="{{ old.nom ?? user.nom }}" required maxlength="50">
                </div>
                <div class="form-group">
                    <label for="prenom">Prénom <span style="color:var(--red)">*</span></label>
                    <input type="text" class="form-control" id="prenom" name="prenom"
                           value="{{ old.prenom ?? user.prenom }}" required maxlength="50">
                </div>
            </div>
            <div class="form-group">
                <label for="email">Email <span style="color:var(--red)">*</span></label>
                <input type="email" class="form-control" id="email" name="email"
                       value="{{ old.email ?? user.email }}" required>
            </div>

            {# AJOUT DU CHAMP TÉLÉPHONE : Uniquement si pas admin car ils sont à NULL en base #}
            {% if user.role != 'admin' %}
            <div class="form-group">
                <label for="telephone">Téléphone <span style="color:var(--red)">*</span></label>
                <input type="tel" class="form-control" id="telephone" name="telephone"
                       value="{{ old.telephone ?? user.telephone }}" 
                       placeholder="ex: 0612345678">
            </div>
            {% endif %}

            <div class="form-group">
                <label for="password">Nouveau mot de passe</label>
                <input type="password" class="form-control" id="password" name="password"
                       placeholder="Laisser vide pour ne pas modifier" 
                       pattern="(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{8,}"
                       title="Le mot de passe doit contenir au moins 8 caractères, une majuscule et un chiffre."
                       autocomplete="new-password">
                <small style="color:var(--ink-muted);font-size:.8rem;margin-top:.3rem;display:block;">
                    Minimum 8 caractères, une majuscule et un chiffre.
                </small>
            </div>
            <button type="submit" class="btn" style="width:100%;"><i class="fas fa-save"></i> Enregistrer</button>
        </form>

        <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--cream-2);">
            <a href="/compte/supprimer" class="btn btn-danger btn-small">
                <i class="fas fa-trash"></i> Supprimer mon compte
            </a>
        </div>
    </div>
</div>
{% endblock %}
