{% extends 'layouts/base.html.twig' %}
{% set current_route = 'offers' %}
{% block title %}{{ offer ? 'Modifier' : 'Créer' }} une offre{% endblock %}

{% block content %}
<div class="card" style="max-width:660px;margin:0 auto;">
    <div class="card-header">
        <h2><i class="fas fa-briefcase" style="color:var(--violet);"></i>
            {{ offer ? 'Modifier' : 'Créer' }} une offre</h2>
    </div>

    {% include '_partials/alerts.html.twig' %}

    <form method="POST" action="{{ offer ? '/offres/' ~ offer.id ~ '/modifier' : '/offres/creer' }}" novalidate>
        {{ csrf_field()|raw }}

        {# Titre #}
        <div class="form-group">
            <label for="titre">Titre de l'offre <span style="color:var(--red)">*</span></label>
            <input type="text" class="form-control" id="titre" name="titre"
                   value="{{ old.titre ?? offer.titre ?? '' }}" required maxlength="150">
        </div>

        {# Entreprise #}
        <div class="form-group">
            <label>Entreprise</label>
            {% if auth_user.role == 'entreprise' %}
                <div style="padding: 0.6rem 1rem; background: var(--violet-light); color: var(--violet); border-radius: 8px; border: 1px solid var(--violet); display: flex; align-items: center; gap: 0.5rem; font-weight: 600; width: fit-content;">
                    <i class="fas fa-building"></i>
                    {{ my_company.nom|default('Votre entreprise') }}
                </div>
                <input type="hidden" name="entreprise_id" value="{{ my_company.id }}">
            {% else %}
                <select class="form-control" id="entreprise_id" name="entreprise_id" required>
                    <option value="">Sélectionner une entreprise</option>
                    {% for c in companies %}
                    <option value="{{ c.id }}" {% if (old.entreprise_id ?? offer.entreprise_id ?? 0) == c.id %}selected{% endif %}>
                        {{ c.nom }}
                    </option>
                    {% endfor %}
                </select>
            {% endif %}
        </div>

        {# Description #}
        <div class="form-group">
            <label for="description">Description du poste <span style="color:var(--red)">*</span></label>
            <textarea class="form-control" id="description" name="description" rows="5" required>{{ old.description ?? offer.description ?? '' }}</textarea>
        </div>

        {# Compétences #}
        <div class="form-group">
            <label>Compétences ciblées</label>
            <div style="display:flex;flex-wrap:wrap;gap:.5rem;">
                {% for skill in skills %}
                <label style="display:inline-flex;align-items:center;gap:.4rem;background:var(--cream-2);padding:.35rem .7rem;border-radius:999px;cursor:pointer;font-size:.85rem;border:1.5px solid var(--cream-3);transition:all .15s;">
                    <input type="checkbox" name="skills[]" value="{{ skill.id }}"
                           {% if skill.id in (selected_skills ?? []) %}checked{% endif %}
                           style="accent-color:var(--violet);">
                    {{ skill.nom }}
                </label>
                {% endfor %}
            </div>
        </div>

        {# Ligne : Salaire, Durée #}
        <div style="display:grid;grid-template-columns: 1fr 1fr; gap:1rem;">
            <div class="form-group">
                <label for="remuneration">Rémunération (€/mois) <span style="color:var(--red)">*</span></label>
                <input type="number" class="form-control" id="remuneration" name="remuneration"
                       value="{{ old.remuneration ?? offer.remuneration ?? 0 }}" min="0" max="9999" required>
                <small>Max 9 999 €</small>
            </div>
            <div class="form-group">
                <label for="duree_mois">Durée (mois) <span style="color:var(--red)">*</span></label>
                <input type="number" class="form-control" id="duree_mois" name="duree_mois"
                       value="{{ old.duree_mois ?? offer.duree_mois ?? 1 }}" min="1" max="12" required>
            </div>
        </div>

        {# Date #}
        <div class="form-group">
            <label for="date_publication">Date de publication</label>
            <input type="date" class="form-control" id="date_publication" name="date_publication"
                   value="{{ old.date_publication ?? offer.date_publication ?? today }}">
            <small style="color:var(--violet);">Par défaut : aujourd'hui.</small>
        </div>

        {# Actions #}
        <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:.8rem; margin-top:1.5rem; padding-top:1.5rem; border-top:1px solid var(--cream-3);">
            <div style="display:flex; gap:.8rem;">
                <button type="submit" class="btn">
                    <i class="fas fa-save"></i> {{ offer ? 'Enregistrer' : 'Publier' }}
                </button>
                <a href="{{ offer ? '/offres/' ~ offer.id : '/offres' }}" class="btn btn-outline">Annuler</a>
            </div>

            {# Bouton de suppression (uniquement en modification) #}
            {% if offer %}
                {% set is_owner = (auth_user.role == 'entreprise' and my_company and offer.entreprise_id == my_company.id) %}
                {% if auth_user.role in ['admin', 'pilote'] or is_owner %}
                    <button type="submit" 
                            formaction="/offres/{{ offer.id }}/supprimer" 
                            onclick="return confirm('Attention : Cette action supprimera définitivement l\'offre. Confirmer ?')" 
                            class="btn btn-danger">
                        <i class="fas fa-trash"></i> Supprimer
                    </button>
                {% endif %}
            {% endif %}
        </div>
    </form>
</div>
{% endblock %}
