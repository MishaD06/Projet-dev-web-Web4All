<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}StageLab{% endblock %} - StageLab</title>
    
    <link rel="icon" type="image/x-icon" href="/assets/favicon/favicon.ico">
    <link rel="icon" type="image/png" sizes="96x96" href="/assets/favicon/favicon-96x96.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicon/apple-touch-icon.png">
    <link rel="manifest" href="/assets/favicon/site.webmanifest">

    <meta name="description" content="{% block description %}StageLab : la plateforme de gestion de stages pour les étudiants du CESI.{% endblock %}">
    <meta name="keywords" content="{% block keywords %}stage, alternance, CESI, étudiant, entreprise, candidature{% endblock %}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    {% block head %}{% endblock %}
</head>
<body>
    <header>
        <div class="header-container">
            <div class="logo">
                <a href="/">Stage<span>Lab</span></a>
            </div>

            {% if not auth_user %}
            <div class="search-bar">
                <input type="text" placeholder="Titre, entreprise, compétence...">
                <button><i class="fas fa-search"></i> Rechercher</button>
            </div>
            {% endif %}

            <button class="burger" aria-label="Menu"><i class="fas fa-bars"></i></button>

            <nav class="nav-menu" aria-label="Navigation principale">
                <ul>
                    {% if not auth_user %}
                        <li><a href="/" {% if current_route == 'home' %}class="active"{% endif %}><i class="fas fa-home"></i> Accueil</a></li>
                        <li><a href="/offres" {% if current_route == 'offers' %}class="active"{% endif %}><i class="fas fa-briefcase"></i> Offres</a></li>
                        <li><a href="/entreprises" {% if current_route == 'companies' %}class="active"{% endif %}><i class="fas fa-building"></i> Entreprises</a></li>
                        <li><a href="/connexion"><i class="fas fa-sign-in-alt"></i> Connexion</a></li>

                    {% elseif auth_user.role == 'visiteur' %}
                        {# Menu restreint pour le compte en attente #}
                        <li><a href="/inscription/en-attente" class="active"><i class="fas fa-clock"></i> En attente</a></li>
                        <li><a href="/deconnexion"><i class="fas fa-sign-out-alt"></i> Déconnexion</a></li>

                    {% elseif auth_user.role == 'etudiant' %}
                        <li><a href="/dashboard" {% if current_route == 'dashboard' %}class="active"{% endif %}><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                        <li><a href="/offres" {% if current_route == 'offers' %}class="active"{% endif %}><i class="fas fa-briefcase"></i> Offres</a></li>
                        <li><a href="/entreprises" {% if current_route == 'companies' %}class="active"{% endif %}><i class="fas fa-building"></i> Entreprises</a></li>
                        <li><a href="/stats" {% if current_route == 'stats' %}class="active"{% endif %}><i class="fas fa-chart-bar"></i> Stats</a></li>
                        <li><a href="/wishlist" {% if current_route == 'wishlist' %}class="active"{% endif %}><i class="fas fa-heart"></i> Wishlist</a></li>
                        <li><a href="/candidatures" {% if current_route == 'applications' %}class="active"{% endif %}><i class="fas fa-file-alt"></i> Candidatures</a></li>
                        <li><a href="/profil" {% if current_route == 'profile' %}class="active"{% endif %}><i class="fas fa-user"></i> Profil</a></li>
                        <li><a href="/deconnexion"><i class="fas fa-sign-out-alt"></i> Déconnexion</a></li>

                    {% elseif auth_user.role == 'entreprise' %}
                        <li><a href="/dashboard/entreprise" {% if current_route == 'dashboard' %}class="active"{% endif %}><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                        <li><a href="/entreprise/offres" {% if current_route == 'my_offers' %}class="active"{% endif %}><i class="fas fa-list"></i> Mes Offres</a></li>
                        <li><a href="/entreprise/candidatures" {% if current_route == 'applications' %}class="active"{% endif %}><i class="fas fa-users"></i> Candidatures</a></li>
                        <li><a href="/entreprise/modifier" {% if current_route == 'edit_company' %}class="active"{% endif %}><i class="fas fa-edit"></i> Ma Fiche</a></li>
                        <li><a href="/deconnexion"><i class="fas fa-sign-out-alt"></i> Déconnexion</a></li>

                    {% elseif auth_user.role == 'pilote' %}
                        <li><a href="/dashboard/pilote" {% if current_route == 'dashboard' %}class="active"{% endif %}><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                        <li><a href="/offres" {% if current_route == 'offers' %}class="active"{% endif %}><i class="fas fa-briefcase"></i> Offres</a></li>
                        <li><a href="/entreprises" {% if current_route == 'companies' %}class="active"{% endif %}><i class="fas fa-building"></i> Entreprises</a></li>
                        <li><a href="/admin/utilisateurs" {% if current_route == 'users' %}class="active"{% endif %}><i class="fas fa-users"></i> Étudiants</a></li>
                        <li><a href="/stats" {% if current_route == 'stats' %}class="active"{% endif %}><i class="fas fa-chart-bar"></i> Stats</a></li>
                        <li><a href="/profil"><i class="fas fa-user"></i> Profil</a></li>
                        <li><a href="/deconnexion"><i class="fas fa-sign-out-alt"></i> Déconnexion</a></li>

                    {% else %}{# admin #}
                        <li><a href="/dashboard/admin" {% if current_route == 'dashboard' %}class="active"{% endif %}><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                        <li><a href="/offres" {% if current_route == 'offers' %}class="active"{% endif %}><i class="fas fa-briefcase"></i> Offres</a></li>
                        <li><a href="/entreprises" {% if current_route == 'companies' %}class="active"{% endif %}><i class="fas fa-building"></i> Entreprises</a></li>
                        <li><a href="/admin/utilisateurs" {% if current_route == 'users' %}class="active"{% endif %}><i class="fas fa-users-cog"></i> Utilisateurs</a></li>
                        <li><a href="/stats" {% if current_route == 'stats' %}class="active"{% endif %}><i class="fas fa-chart-bar"></i> Stats</a></li>
                        <li><a href="/profil"><i class="fas fa-user-cog"></i> Profil</a></li>
                        <li><a href="/deconnexion"><i class="fas fa-sign-out-alt"></i> Déconnexion</a></li>
                    {% endif %}
                </ul>
            </nav>
        </div>
    </header>

    <main>
        {% block content %}{% endblock %}
    </main>

    <footer>
        <p>&copy; 2026 StageLab — Tous droits réservés — <a href="/mentions-legales">Mentions légales</a></p>
    </footer>

    <script src="/js/main.js"></script>
    {% block scripts %}{% endblock %}
</body>
</html>
