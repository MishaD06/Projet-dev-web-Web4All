{% extends 'layouts/base.html.twig' %}
{% block title %}Connexion{% endblock %}
{% block description %}Connectez-vous à StageLab pour accéder aux offres de stage.{% endblock %}

{% block content %}
<div class="card" style="max-width:440px;margin:1rem auto;">
    <div class="card-header">
        <h2><i class="fas fa-sign-in-alt" style="color:var(--violet);margin-right:.5rem;"></i> Connexion</h2>
    </div>

    {% if error %}
    <div style="background:var(--red-lt);color:var(--red);padding:.8rem 1rem;border-radius:var(--radius-md);margin-bottom:1rem;font-size:.9rem;">
        <i class="fas fa-exclamation-circle"></i> {{ error }}
    </div>
    {% endif %}

    <form method="POST" action="/connexion" novalidate>
        {{ csrf_field()|raw }}

        <div class="form-group">
            <label for="email">Email <span style="color:var(--red)">*</span></label>
            <input type="email" class="form-control" id="email" name="email"
                   placeholder="exemple@cesi.fr" required autocomplete="email">
        </div>

        <div class="form-group">
            <label for="password">Mot de passe <span style="color:var(--red)">*</span></label>
            <input type="password" class="form-control" id="password" name="password"
                   placeholder="••••••••" required autocomplete="current-password">
        </div>

        <button type="submit" class="btn" style="width:100%;">
            <i class="fas fa-sign-in-alt"></i> Se connecter
        </button>

        <p style="text-align:center;margin-top:1.2rem;font-size:.9rem;color:var(--ink-muted);">
            Pas encore de compte ?
            <a href="/inscription" style="color:var(--violet);font-weight:500;">Créer un compte</a>
        </p>
    </form>
</div>
{% endblock %}
