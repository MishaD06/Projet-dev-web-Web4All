{% extends 'layouts/base.html.twig' %}

{# Ajout d'un titre de page propre #}
{% block title %}Demande en cours d'examen{% endblock %}

{% block content %}
{# Conteneur principal centré verticalement et horizontalement #}
<div style="display: flex; justify-content: center; align-items: center; min-height: 70vh; padding: 2rem;">
    
    {# Carte avec espacements généreux et ombre douce #}
    <div class="card" style="max-width: 600px; width: 100%; text-align: center; padding: 3rem 2rem; border-radius: var(--radius-lg); box-shadow: 0 10px 25px rgba(0,0,0,0.05); border: 1px solid var(--cream-2);">
        
        {# Icône mise en valeur dans un cercle #}
        <div style="margin-bottom: 2.5rem;">
            <div style="display: inline-flex; background: #fff3e0; color: orange; width: 80px; height: 80px; border-radius: 50%; align-items: center; justify-content: center; font-size: 2.5rem; border: 4px solid white; box-shadow: 0 4px 10px rgba(0,0,0,0.03);">
                <i class="fas fa-clock fa-spin-pulse" style="--fa-animation-duration: 3s;"></i>
            </div>
        </div>

        {# Titre plus grand et mieux espacé #}
        <h1 style="font-size: 1.8rem; margin-bottom: 1.5rem; color: var(--ink); font-weight: 700;">Demande en cours d'examen</h1>
        
        {# Bloc de texte aéré #}
        <div style="line-height: 1.8; color: var(--ink-soft); font-size: 1.05rem; margin-bottom: 3rem;">
            <p style="margin-bottom: 1rem;">
                Merci pour votre inscription ! Un administrateur de notre équipe doit maintenant <strong>valider vos documents</strong>.
            </p>
            <p style="margin: 0;">
                Vous recevrez un accès complet dès que votre compte sera approuvé. N'hésitez pas à vérifier vos emails régulièrement.
            </p>
        </div>

        {# Bouton plus large et assorti à l'icône #}
        <a href="/" class="btn btn-primary" style="padding: 1rem 2.5rem; font-size: 1rem; display: inline-flex; align-items: center; gap: 10px; background-color: orange; border-color: orange;">
            <i class="fas fa-arrow-left"></i> Retour à l'accueil
        </a>
    </div>
</div>
{% endblock %}
