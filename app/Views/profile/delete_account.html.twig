{% extends 'layouts/base.html.twig' %}
{% block title %}Supprimer mon compte{% endblock %}

{% block content %}
<div style="max-width:500px;margin:0 auto;">
    <div class="card" style="border:2px solid var(--red-lt);">
        <div class="card-header">
            <h2 style="color:var(--red);"><i class="fas fa-exclamation-triangle"></i> Supprimer mon compte</h2>
        </div>

        <div style="background:var(--red-lt);color:var(--red);padding:1rem;border-radius:var(--radius-md);margin-bottom:1.5rem;font-size:.9rem;line-height:1.6;">
            <strong>Cette action est irréversible.</strong><br>
            Toutes vos données seront supprimées définitivement : candidatures, wishlist, évaluations.
        </div>

        {% if error is defined and error %}
        <div style="background:var(--amber-lt);color:var(--amber);padding:.8rem 1rem;border-radius:var(--radius-md);margin-bottom:1rem;">
            <i class="fas fa-exclamation-circle"></i> {{ error }}
        </div>
        {% endif %}

        <form method="POST" action="/compte/supprimer" novalidate>
            {{ csrf_field()|raw }}

            <div class="form-group">
                <label for="password">Votre mot de passe actuel <span style="color:var(--red)">*</span></label>
                <input type="password" class="form-control" id="password" name="password"
                       placeholder="Confirmez votre identité" required autocomplete="current-password">
            </div>

            <div class="form-group">
                <label for="confirm">Tapez <strong>SUPPRIMER</strong> pour confirmer <span style="color:var(--red)">*</span></label>
                <input type="text" class="form-control" id="confirm" name="confirm"
                       placeholder="SUPPRIMER" required>
            </div>

            <div style="display:flex;gap:.8rem;flex-wrap:wrap;margin-top:.5rem;">
                <button type="submit" class="btn btn-danger" style="flex:1;">
                    <i class="fas fa-trash"></i> Supprimer définitivement
                </button>
                <a href="/profil" class="btn btn-outline" style="flex:1;">
                    <i class="fas fa-times"></i> Annuler
                </a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
