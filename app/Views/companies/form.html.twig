{% extends 'layouts/base.html.twig' %}
{% set current_route = 'companies' %}
{% block title %}{{ company ? 'Modifier' : 'Créer' }} une entreprise{% endblock %}

{% block content %}
<div class="card" style="max-width:660px;margin:0 auto;">
    <div class="card-header">
        <h2><i class="fas fa-building" style="color:var(--violet);"></i>
            {{ company ? 'Modifier' : 'Ajouter' }} une entreprise</h2>
    </div>

    {% include '_partials/alerts.html.twig' %}

    {# Correction : action="" permet de poster sur l'URL actuelle (évite les erreurs de routes complexes) #}
    <form method="POST" action="" novalidate>
        {{ csrf_field()|raw }}

        <div class="form-group">
            <label for="nom">Nom de l'entreprise <span style="color:var(--red)">*</span></label>
            <input type="text" class="form-control" id="nom" name="nom"
                   value="{{ old.nom ?? company.nom ?? '' }}" required maxlength="100">
        </div>

        {# CHAMP LOCALISATION #}
        <div class="form-group">
            <label for="localite">Localisation / Ville <span style="color:var(--red)">*</span></label>
            <input type="text" class="form-control" id="localite" name="localite"
                   value="{{ old.localite ?? company.localite ?? '' }}" required placeholder="Ex: Paris, Lyon..." maxlength="100">
        </div>

        <div class="form-group">
            <label for="description">Description <span style="color:var(--red)">*</span></label>
            <textarea class="form-control" id="description" name="description" rows="4" required>{{ old.description ?? company.description ?? '' }}</textarea>
        </div>

        <div class="form-group">
            <label for="email_contact">Email de contact (Public) <span style="color:var(--red)">*</span></label>
            <input type="email" class="form-control" id="email_contact" name="email_contact"
                   value="{{ old.email_contact ?? company.email_contact ?? '' }}" required placeholder="contact@entreprise.fr">
        </div>

        <div class="form-group">
            <label for="telephone_contact">Téléphone <span style="color:var(--red)">*</span></label>
            <input type="tel" class="form-control" id="telephone_contact" name="telephone_contact"
                   value="{{ old.telephone_contact ?? company.telephone_contact ?? '' }}" required placeholder="01 23 45 67 89">
        </div>

        {# SECTION COMPTE : Uniquement si c'est une NOUVELLE entreprise #}
        {% if not company %}
            <hr style="margin: 2rem 0; border: 0; border-top: 1px solid #eee;">
            <h3 style="margin-bottom: 1rem;"><i class="fas fa-user-lock"></i> Responsable du compte</h3>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="form-group">
                    <label for="user_nom">Nom du contact <span style="color:var(--red)">*</span></label>
                    <input type="text" class="form-control" id="user_nom" name="user_nom"
                           value="{{ old.user_nom ?? '' }}" required placeholder="Ex: Dupont">
                </div>
                <div class="form-group">
                    <label for="user_prenom">Prénom du contact <span style="color:var(--red)">*</span></label>
                    <input type="text" class="form-control" id="user_prenom" name="user_prenom"
                           value="{{ old.user_prenom ?? '' }}" required placeholder="Ex: Jean">
                </div>
            </div>

            <div class="form-group">
                <label for="user_email">Email de connexion (Privé) <span style="color:var(--red)">*</span></label>
                <input type="email" class="form-control" id="user_email" name="user_email"
                       value="{{ old.user_email ?? '' }}" required placeholder="admin@entreprise.fr">
                <small style="color: #666;">Cet email servira à l'entreprise pour se connecter au dashboard.</small>
            </div>

            <div class="form-group">
                <label for="user_password">Mot de passe provisoire <span style="color:var(--red)">*</span></label>
                <input type="password" class="form-control" id="user_password" name="user_password"
                       required placeholder="********">
            </div>
        {% endif %}

        <div style="display:flex;gap:.8rem;flex-wrap:wrap;margin-top:1.5rem;">
            <button type="submit" class="btn"><i class="fas fa-save"></i> Enregistrer</button>
            <a href="{{ company ? (Auth.role == 'entreprise' ? '/dashboard/entreprise' : '/entreprises/' ~ company.id) : '/entreprises' }}" class="btn btn-outline">
                <i class="fas fa-times"></i> Annuler
            </a>
        </div>
    </form>
</div>
{% endblock %}
