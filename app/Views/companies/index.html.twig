{% extends 'layouts/base.html.twig' %}
{% set current_route = 'companies' %}
{% block title %}Entreprises{% endblock %}
{% block description %}Recherchez des entreprises proposant des stages sur StageLab.{% endblock %}

{% block content %}
<div class="page-header">
    <h1>Entreprises</h1>
    {% if auth_user and auth_user.role in ['admin','pilote'] %}
    <a href="/entreprises/creer" class="btn"><i class="fas fa-plus"></i> Nouvelle entreprise</a>
    {% endif %}
</div>

<div class="card">
    <form class="filters-bar" action="/entreprises" method="get">
        <input type="text" name="nom" class="form-control" placeholder="Nom de l'entreprise"
               value="{{ filters.nom }}" style="flex:2;min-width:160px;">
        <button type="submit" class="btn"><i class="fas fa-search"></i> Rechercher</button>
    </form>
</div>

{% if companies.data is empty %}
<div class="card">
    <div class="empty-state">
        <i class="fas fa-building"></i>
        <p>Aucune entreprise trouvée.</p>
        <a href="/entreprises" class="btn">Voir toutes les entreprises</a>
    </div>
</div>
{% else %}
<div class="offers-grid" style="grid-template-columns:repeat(auto-fill,minmax(280px,1fr));">
    {% for company in companies.data %}
    {% set initials = company.nom|slice(0,2)|upper %}
    {% set colors = ['#6c4de6','#c9964a','#2e7d59','#c0392b','#185FA5','#854F0B'] %}
    {% set color = colors[loop.index0 % colors|length] %}
    <div class="offer-card">
        <div style="display:flex;align-items:center;gap:1rem;margin-bottom:.8rem;">
            <div style="width:46px;height:46px;background:{{ color }};border-radius:14px;display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:1rem;flex-shrink:0;">
                {{ initials }}
            </div>
            <div>
                <div class="offer-title" style="font-size:1rem;">{{ company.nom }}</div>
                <div style="color:var(--ink-muted);font-size:.85rem;">
                    {% if company.note_moyenne %}
                    <i class="fas fa-star" style="color:#c9964a;"></i> {{ company.note_moyenne }} ({{ company.nb_avis }} avis)
                    {% else %}
                    Pas encore évalué
                    {% endif %}
                </div>
            </div>
        </div>
        <p style="color:var(--ink-muted);margin-bottom:.8rem;font-size:.875rem;">{{ company.description|slice(0,80) }}{% if company.description|length > 80 %}…{% endif %}</p>
        <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;padding-top:.8rem;border-top:1px solid var(--cream-2);">
            <div class="action-group">
                <a href="/entreprises/{{ company.id }}" class="btn btn-small">Voir</a>
                {% if auth_user and auth_user.role in ['admin','pilote'] %}
                <a href="/entreprises/{{ company.id }}/modifier" class="btn btn-small btn-outline" title="Modifier"><i class="fas fa-edit"></i></a>
                <form method="POST" action="/entreprises/{{ company.id }}/supprimer" style="display:inline;" onsubmit="return confirm('Supprimer {{ company.nom }} ?')">
                    {{ csrf_field()|raw }}
                    <button type="submit" class="btn btn-small btn-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                </form>
                {% endif %}
            </div>
        </div>
    </div>
    {% endfor %}
</div>

{% include '_partials/pagination.html.twig' with {paginator: companies, base_url: '/entreprises', filters: filters} %}
{% endif %}
{% endblock %}
