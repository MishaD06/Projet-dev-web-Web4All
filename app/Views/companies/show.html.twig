{% extends 'layouts/base.html.twig' %}
{% set current_route = 'companies' %}
{% block title %}{{ company.nom }}{% endblock %}
{% block description %}Découvrez les offres et évaluations de {{ company.nom }} sur StageLab.{% endblock %}

{% block content %}

{# Messages Flash #}
{% if app.request.query.get('success') == 'avis_publie' %}
<div style="background:var(--green-lt);color:var(--green);padding:.8rem 1rem;border-radius:var(--radius-md);margin-bottom:1rem;border:1px solid var(--green);">
    <i class="fas fa-check-circle"></i> Votre évaluation a bien été enregistrée.
</div>
{% endif %}

{% if app.request.query.get('error') %}
<div style="background:var(--red-lt);color:var(--red);padding:.8rem 1rem;border-radius:var(--radius-md);margin-bottom:1rem;border:1px solid var(--red);">
    <i class="fas fa-exclamation-circle"></i> 
    {% if app.request.query.get('error') == 'already_reviewed' %}
        Vous avez déjà publié un avis pour cette entreprise.
    {% elseif app.request.query.get('error') == 'note_invalide' %}
        La note doit être comprise entre 1 et 5.
    {% else %}
        Une erreur est survenue lors de l'enregistrement.
    {% endif %}
</div>
{% endif %}

<div class="card">
    <div style="display:flex;align-items:center;gap:1.2rem;flex-wrap:wrap;">
        <div style="width:70px;height:70px;background:var(--violet);border-radius:20px;display:flex;align-items:center;justify-content:center;color:white;font-size:1.8rem;font-weight:700;flex-shrink:0;">
            {{ company.nom|slice(0,2)|upper }}
        </div>
        <div style="flex:1;min-width:200px;">
            <h1 style="font-size:1.8rem;margin-bottom:.2rem;">{{ company.nom }}</h1>
            <p style="color:var(--ink-muted);font-size:.95rem;">
                <i class="fas fa-map-marker-alt" style="color:var(--violet);"></i> {{ company.localite }} &nbsp;·&nbsp;
                {% if reviews %}
                <i class="fas fa-star" style="color:var(--gold);"></i> Avis ({{ reviews|length }})
                {% else %}
                Pas encore d'avis
                {% endif %}
            </p>
        </div>
        {% if auth_user and auth_user.role in ['admin','pilote'] %}
        <a href="/entreprises/{{ company.id }}/modifier" class="btn btn-small btn-outline"><i class="fas fa-edit"></i> Modifier</a>
        {% endif %}
    </div>
</div>

{# On ajoute la classe "company-show-grid" pour le responsive #}
<div class="company-show-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;align-items:start;">

    {# Infos #}
    <div class="card">
        <h3 style="margin-bottom:1rem;font-size:1.1rem;"><i class="fas fa-info-circle" style="color:var(--violet);"></i> À propos</h3>
        <p style="color:var(--ink-soft);line-height:1.7;margin-bottom:1rem;">{{ company.description }}</p>
        
        <p style="font-size:.9rem;margin-bottom:.4rem;">
            <i class="fas fa-envelope" style="color:var(--violet);width:20px;"></i> {{ company.email_contact }}
        </p>

        {% if company.telephone_contact %}
        <p style="font-size:.9rem;margin-bottom:.4rem;">
            <i class="fas fa-phone" style="color:var(--violet);width:20px;"></i> 
            <a href="tel:{{ company.telephone_contact }}" style="color:inherit;text-decoration:none;">{{ company.telephone_contact }}</a>
        </p>
        {% endif %}
    </div>

    {# Formulaire d'avis (Réservé aux Admins et Pilotes) #}
    {% if auth_user and auth_user.role in ['admin', 'pilote'] %}
    <div class="card">
        <h3 style="margin-bottom:1rem;font-size:1.1rem;"><i class="fas fa-pen" style="color:var(--violet);"></i> Évaluer l'entreprise</h3>
        
        {% if hasReviewed %}
            <div style="text-align:center;padding:1.5rem;background:var(--cream-lt);border-radius:var(--radius-md);border:1px dashed var(--violet-lt);">
                <i class="fas fa-check-circle" style="color:var(--green);font-size:2rem;margin-bottom:.8rem;display:block;"></i>
                <p style="font-size:.9rem;color:var(--ink-soft);">Vous avez déjà évalué cette entreprise.</p>
            </div>
        {% else %}
            <form method="POST" action="/entreprises/{{ company.id }}/evaluer">
                {{ csrf_field()|raw }}
                <div class="form-group" style="margin-bottom:1rem;">
                    <label for="note">Note / 5</label>
                    <select class="form-control" id="note" name="note" required>
                        <option value="5">5 ★★★★★</option>
                        <option value="4">4 ★★★★☆</option>
                        <option value="3">3 ★★★☆☆</option>
                        <option value="2">2 ★★☆☆☆</option>
                        <option value="1">1 ★☆☆☆☆</option>
                    </select>
                </div>
                <div class="form-group" style="margin-bottom:1rem;">
                    <label for="commentaire">Votre retour d'expérience (Optionnel)</label>
                    <textarea class="form-control" id="commentaire" name="commentaire" rows="3" placeholder="Racontez-nous..."></textarea>
                </div>
                <button type="submit" class="btn" style="width:100%;"><i class="fas fa-paper-plane"></i> Publier l'évaluation</button>
            </form>
        {% endif %}
    </div>
    {% endif %}
</div>

{# Offres #}
{% if offers %}
<div class="card" style="margin-top:1.2rem;">
    <div class="card-header" style="margin-bottom:1rem;">
        <h3><i class="fas fa-briefcase" style="color:var(--violet);"></i> Offres de stage</h3>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(280px, 1fr));gap:1rem;">
        {% for offer in offers %}
        <div style="padding:1rem;border:1px solid var(--cream-2);border-radius:var(--radius-md);background:var(--white);">
            <div style="font-weight:600;margin-bottom:.5rem;color:var(--ink);">{{ offer.titre }}</div>
            <div style="font-size:.85rem;color:var(--green);font-weight:600;margin-bottom:.8rem;">
                <i class="fas fa-euro-sign"></i> {{ offer.remuneration|number_format(0, ',', ' ') }} € / mois
            </div>
            <a href="/offres/{{ offer.id }}" class="btn btn-small btn-outline" style="width:100%;text-align:center;">Voir les détails</a>
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{# Liste des Avis #}
{% if reviews %}
<div class="card" style="margin-top:1.2rem;">
    <div class="card-header" style="margin-bottom:1rem;">
        <h3><i class="fas fa-comment-alt" style="color:var(--violet);"></i> Évaluations ({{ reviews|length }})</h3>
    </div>
    <div style="display:flex;flex-direction:column;gap:1rem;">
        {% for review in reviews %}
        <div style="padding:1rem;background:var(--cream-lt);border-radius:var(--radius-md);">
            <div style="display:flex;justify-content:space-between;margin-bottom:.5rem;">
                <span style="font-weight:600;font-size:.9rem;">
                    {# Affichage discret de l'auteur si c'est un pilote/admin #}
                    {{ review.prenom }} {{ review.nom|slice(0,1) }}. 
                    <span class="badge badge-info" style="font-size:0.65rem; margin-left: 0.5rem;">Évaluateur</span>
                </span>
                <span style="color:var(--gold);">
                    {% for i in 1..5 %}{% if i <= review.note %}★{% else %}☆{% endif %}{% endfor %}
                </span>
            </div>
            {% if review.commentaire %}
            <p style="font-size:.9rem;color:var(--ink-soft);line-height:1.5;font-style:italic;">"{{ review.commentaire }}"</p>
            {% endif %}
            <div style="font-size:.75rem;color:var(--ink-muted);margin-top:.5rem;text-align:right;">
                Posté le {{ review.date_review|date('d/m/Y') }}
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{% endblock %}
