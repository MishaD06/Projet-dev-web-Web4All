{% extends "layout.html.twig" %}

{% block title %}Devenir Partenaire{% endblock %}

{% block content %}
<div class="container mt-5">
    <h1>Demande de compte Entreprise</h1>
    <p class="text-muted">Veuillez envoyer un justificatif (KBIS, fiche SIREN) pour valider votre identité.</p>

    {% if errors %}
        <div class="alert alert-danger">
            {% for error in errors %}
                <p class="mb-0">{{ error }}</p>
            {% endfor %}
        </div>
    {% endif %}

    <form action="/devenir-partenaire" method="POST" enctype="multipart/form-data" class="mt-4">
        {# Protection CSRF obligatoire #}
        {{ csrf_field()|raw }}

        <div class="mb-3">
            <label for="document" class="form-label">Justificatif (Format PDF uniquement, max 5Mo)</label>
            <input type="file" name="document" id="document" class="form-control" accept=".pdf" required>
        </div>

        <button type="submit" class="btn btn-primary">Envoyer la demande</button>
    </form>
</div>
{% endblock %}
