{% extends 'layouts/base.html.twig' %}

{% block title %}Candidatures reçues{% endblock %}

{% block content %}
<div class="page-header">
    <h1>Candidatures reçues</h1>
    <a href="/dashboard/entreprise" class="btn btn-outline">
        <i class="fas fa-arrow-left"></i> Dashboard
    </a>
</div>

{% if candidatures is empty %}
<div class="card">
    <div class="empty-state">
        <i class="fas fa-inbox"></i>
        <p>Aucune candidature reçue pour l'instant.</p>
        <a href="/entreprise/offres" class="btn">Voir mes offres</a>
    </div>
</div>
{% else %}
<div class="card">
    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>Candidat</th>
                    <th>Email</th>
                    <th>Offre</th>
                    <th>Date</th>
                    <th>Documents</th>
                    <th>Statut</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for c in candidatures %}
                <tr>
                    <td data-label="Candidat" style="font-weight:500;">{{ c.etudiant_prenom }} {{ c.etudiant_nom }}</td>
                    <td data-label="Email" style="color:var(--ink-muted);">{{ c.etudiant_email }}</td>
                    <td data-label="Offre" style="font-weight:600; color:var(--violet);">{{ c.offre_titre }}</td>
                    <td data-label="Date" style="white-space:nowrap;color:var(--ink-muted);">{{ c.date_candidature|date('d/m/Y') }}</td>
                    <td data-label="Documents">
                        <div class="action-group">
                            <a href="/uploads/{{ c.cv_path }}" target="_blank" class="btn btn-small btn-outline" style="color:var(--red);">
                                <i class="fas fa-file-pdf"></i> CV
                            </a>

                            {% if c.lettre_motivation %}
                            <button type="button" class="btn btn-small btn-outline" 
                                    onclick="showLetter('{{ c.etudiant_prenom }} {{ c.etudiant_nom }}', '{{ c.lettre_motivation|escape('js') }}')">
                                <i class="fas fa-envelope-open-text"></i> Lettre
                            </button>
                            {% endif %}
                        </div>
                    </td>
                    <td data-label="Statut">
                        {% if c.statut == 'acceptee' %}
                            <span class="badge badge-success">Acceptée</span>
                        {% elseif c.statut == 'refusee' %}
                            <span class="badge badge-danger">Refusée</span>
                        {% else %}
                            <span class="badge badge-warning">En attente</span>
                        {% endif %}
                    </td>
                    <td data-label="Action">
                        {% if c.statut == 'en_attente' %}
                        <div class="action-group">
                            <form method="POST" action="/entreprise/candidatures/{{ c.id }}/statut" style="display:inline;">
                                {{ csrf_field()|raw }}
                                <input type="hidden" name="statut" value="acceptee">
                                <button type="submit" class="btn btn-small" style="background:var(--green); border-color:var(--green);" onclick="return confirm('Accepter cette candidature ?')">
                                    <i class="fas fa-check"></i>
                                </button>
                            </form>
                            <form method="POST" action="/entreprise/candidatures/{{ c.id }}/statut" style="display:inline;">
                                {{ csrf_field()|raw }}
                                <input type="hidden" name="statut" value="refusee">
                                <button type="submit" class="btn btn-small btn-danger" onclick="return confirm('Refuser cette candidature ?')">
                                    <i class="fas fa-times"></i>
                                </button>
                            </form>
                        </div>
                        {% else %}
                            <span style="color:var(--ink-muted);font-size:.85rem;">Traité</span>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{# STRUCTURE DE LA MODALE #}
<div id="letterModal" class="modal-overlay" style="display:none;">
    <div class="modal-card">
        <div class="modal-header">
            <h3>Lettre de Motivation</h3>
            <button onclick="closeModal()" class="modal-close">&times;</button>
        </div>
        <div id="letterContent" class="modal-body">
            {# Texte injecté par JS #}
        </div>
        <div class="modal-footer">
            <button onclick="closeModal()" class="btn btn-outline btn-small">Fermer</button>
        </div>
    </div>
</div>

<script>
function showLetter(name, content) {
    const modal = document.getElementById('letterModal');
    const contentBox = document.getElementById('letterContent');
    const titleBox = modal.querySelector('.modal-header h3');

    contentBox.innerText = content;
    titleBox.innerText = "Lettre de " + name;
    modal.style.display = 'flex';
}

function closeModal() {
    document.getElementById('letterModal').style.display = 'none';
}

window.onclick = function(event) {
    let modal = document.getElementById('letterModal');
    if (event.target == modal) closeModal();
}
</script>
{% endblock %}
